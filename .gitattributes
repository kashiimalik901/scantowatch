# Shell scripts and CI configs run on Linux runners. If Git checks them out with
# CRLF, bash fails with obscure "\r: command not found" errors — force LF.
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# PowerShell stays CRLF for Windows.
*.ps1   text eol=crlf

# Binary assets must never be line-ending converted.
*.png   binary
*.jpg   binary
*.mp4   binary
*.mind  binary
